{
    "name": "mylists",
    "private": true,
    "type": "module",
    "browserslist": [
        ">0.3%, defaults, supports es6-module"
    ],
    "scripts": {
        "lint": "oxlint",
        "test": "vitest",
        "knip": "knip-bun",
        "dk": "drizzle-kit",
        "ui": "bunx shadcn@latest",
        "preview": "bun --bun vite preview",
        "build:server": "bun --bun vite build",
        "dev": "bun --bun vite dev --port 3000",
        "cli": "bun --env-file=.env src/cli/index.ts",
        "build": "bun run build:server && bun run build:cli",
        "seed:achievements": "bun run cli -- seedAchievements",
        "email": "email dev -d src/lib/client/components/emails",
        "build:cli": "bun --bun vite build --config vite.cli.config.ts",
        "auth:generate": "bunx @better-auth/cli@latest generate --y --output src/lib/server/database/schema/auth.schema.ts",
        "new:db": "mkdir -p instance && bun run dk push --force && bun run seed:achievements && bun run cli -- calculateAchievements"
    },
    "dependencies": {
        "@radix-ui/react-avatar": "^1.1.11",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@react-email/components": "1.0.12",
        "@react-email/render": "^2.0.8",
        "@t3-oss/env-core": "^0.13.11",
        "@tanstack/react-query": "^5.100.14",
        "@tanstack/react-router": "^1.170.9",
        "@tanstack/react-router-ssr-query": "^1.167.1",
        "@tanstack/react-start": "^1.168.16",
        "@tanstack/react-store": "^0.11.0",
        "@tanstack/react-table": "^8.21.3",
        "bcrypt": "^6.0.0",
        "better-auth": "^1.6.11",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "commander": "^15.0.0",
        "dedent": "^1.7.2",
        "drizzle-orm": "^0.45.2",
        "ioredis": "^5.11.0",
        "lucide-react": "^1.17.0",
        "nodemailer": "^8.0.10",
        "nprogress": "^0.2.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "posthog-js": "^1.376.4",
        "radix-ui": "^1.4.3",
        "rate-limiter-flexible": "^11.1.0",
        "react": "19.2.6",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.6",
        "react-easy-crop": "^5.5.7",
        "react-email": "6.5.0",
        "react-hook-form": "^7.76.1",
        "react-icons": "^5.6.0",
        "recharts": "^3.8.1",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "user-agents": "^2.1.75",
        "vaul": "^1.1.2",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
